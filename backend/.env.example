# =====================================================================
# Community Hub - Backend Environment Variables (TEMPLATE)
# =====================================================================
# Copy this file to `.env` and fill in real values.
# Never commit `.env` to git. The `.gitignore` already excludes it.
# =====================================================================

# ---------- Server ----------
PORT=5000
NODE_ENV=development

# ---------- Database ----------
# Local dev (Docker): postgresql://postgres:postgres@localhost:5432/community_db
# Production: use a managed database (DigitalOcean, Railway, Neon, etc.)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/community_db"

# ---------- JWT ----------
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=replace-me-with-64-bytes-of-random-base64
JWT_REFRESH_SECRET=replace-me-with-a-different-64-bytes-of-random-base64
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ---------- Cloudinary (file uploads) ----------
# Sign up at https://cloudinary.com (free tier: 25GB)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ---------- SMTP (transactional email) ----------
# Gmail: enable 2FA, then create an App Password at https://myaccount.google.com/apppasswords
# Production: use SendGrid, Mailgun, AWS SES, or Resend
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Community Hub <noreply@communityhub.com>"

# ---------- Manual Payment (Bank Accounts) ----------
# Displayed to users in the "Pay Manually" screen.
# TODO: Replace placeholders with your real accounts.
MANUAL_PAYMENT_INSTRUCTIONS="Pay the exact amount to one of the accounts below, then upload your payment receipt (screenshot or PDF)."
MANUAL_PAYMENT_BANK_NAME="Commercial Bank of Ethiopia"
MANUAL_PAYMENT_ACCOUNT_NUMBER="1000000000000"
MANUAL_PAYMENT_ACCOUNT_HOLDER="Community Hub PLC"
MANUAL_PAYMENT_TELEBIRR_NUMBER="0911000000"
MANUAL_PAYMENT_AWASH_ACCOUNT="0130000000000"

# ---------- Frontend URLs ----------
# Used for CORS, email links, and OAuth callbacks
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000
MOBILE_DEEP_LINK_SCHEME=communityhub

# ---------- Redis (background jobs) ----------
# Local dev: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ---------- Sentry (error tracking) ----------
# Sign up at https://sentry.io (free tier: 5K events/month)
# Leave empty to disable.
SENTRY_DSN=

# ---------- Firebase (push notifications) ----------
# Path to service account JSON. Get from Firebase Console > Project Settings > Service Accounts.
# Leave empty to disable push notifications.
FIREBASE_SERVICE_ACCOUNT=

# ---------- Logging ----------
LOG_LEVEL=info
# Possible: error, warn, info, http, debug
