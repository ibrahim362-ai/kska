{
  "info": {
    "name": "Community Hub API",
    "description": "Multi-platform community engagement API. Includes auth, posts, votes, tickets, memberships, manual payments.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "postId", "value": "" },
    { "key": "paymentId", "value": "" },
    { "key": "proofId", "value": "" },
    { "key": "membershipId", "value": "" },
    { "key": "ticketId", "value": "" },
    { "key": "voteId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        { "name": "Basic Health", "request": { "method": "GET", "url": "{{baseUrl}}/health" } },
        { "name": "Deep Health", "request": { "method": "GET", "url": "{{baseUrl}}/health/deep" } },
        { "name": "API Docs", "request": { "method": "GET", "url": "{{baseUrl}}/docs" } }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Sign Up",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 201) { pm.collectionVariables.set('accessToken', pm.response.json().data.accessToken); pm.collectionVariables.set('refreshToken', pm.response.json().data.refreshToken); pm.collectionVariables.set('userId', pm.response.json().data.user.id); }"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"user@example.com\",\n  \"username\": \"username123\",\n  \"password\": \"TestPass123!\",\n  \"fullName\": \"Test User\"\n}" },
            "url": "{{baseUrl}}/auth/signup"
          }
        },
        {
          "name": "Sign In",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 200) { pm.collectionVariables.set('accessToken', pm.response.json().data.accessToken); pm.collectionVariables.set('refreshToken', pm.response.json().data.refreshToken); pm.collectionVariables.set('userId', pm.response.json().data.user.id); }"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"TestPass123!\"\n}" },
            "url": "{{baseUrl}}/auth/signin"
          }
        },
        { "name": "Get Me", "request": { "method": "GET", "url": "{{baseUrl}}/auth/me" } },
        { "name": "Refresh Token", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }, "url": "{{baseUrl}}/auth/refresh-token" } },
        { "name": "Logout", "request": { "method": "POST", "url": "{{baseUrl}}/auth/logout" } },
        { "name": "Forgot Password", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"email\": \"user@example.com\"\n}" }, "url": "{{baseUrl}}/auth/forgot-password" } },
        { "name": "Change Password", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"TestPass123!\",\n  \"newPassword\": \"NewPass456!\"\n}" }, "url": "{{baseUrl}}/auth/change-password" } }
      ]
    },
    {
      "name": "Users",
      "item": [
        { "name": "List Users (admin)", "request": { "method": "GET", "url": "{{baseUrl}}/users?page=1&limit=20" } },
        { "name": "Get User By ID", "request": { "method": "GET", "url": "{{baseUrl}}/users/{{userId}}" } },
        { "name": "Update Profile", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"fullName\": \"Updated Name\",\n  \"bio\": \"New bio\",\n  \"phone\": \"+251911223344\"\n}" }, "url": "{{baseUrl}}/users/profile" } },
        { "name": "Ban User (admin)", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"isBanned\": true,\n  \"banReason\": \"Spam\"\n}" }, "url": "{{baseUrl}}/users/{{userId}}/ban" } },
        { "name": "Dashboard Stats (admin)", "request": { "method": "GET", "url": "{{baseUrl}}/users/stats" } }
      ]
    },
    {
      "name": "Posts",
      "item": [
        { "name": "List Posts", "request": { "method": "GET", "url": "{{baseUrl}}/posts?page=1&limit=20" } },
        { "name": "Trending Posts", "request": { "method": "GET", "url": "{{baseUrl}}/posts/trending" } },
        { "name": "Get Post", "request": { "method": "GET", "url": "{{baseUrl}}/posts/{{postId}}" } },
        {
          "name": "Create Post",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 201) { pm.collectionVariables.set('postId', pm.response.json().data.id); }"], "type": "text/javascript" } }],
          "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"type\": \"TEXT\",\n  \"content\": \"Hello world!\",\n  \"hashtags\": \"hello community\"\n}" }, "url": "{{baseUrl}}/posts" }
        },
        { "name": "Update Post", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"content\": \"Updated content\"\n}" }, "url": "{{baseUrl}}/posts/{{postId}}" } },
        { "name": "Delete Post", "request": { "method": "DELETE", "url": "{{baseUrl}}/posts/{{postId}}" } },
        { "name": "Like Post", "request": { "method": "POST", "url": "{{baseUrl}}/posts/{{postId}}/like" } },
        { "name": "Save Post", "request": { "method": "POST", "url": "{{baseUrl}}/posts/{{postId}}/save" } },
        { "name": "Get Saved Posts", "request": { "method": "GET", "url": "{{baseUrl}}/posts/saved" } },
        { "name": "Add Comment", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"content\": \"Nice post!\"\n}" }, "url": "{{baseUrl}}/posts/{{postId}}/comments" } },
        { "name": "Get Comments", "request": { "method": "GET", "url": "{{baseUrl}}/posts/{{postId}}/comments" } },
        { "name": "Report Post", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"reason\": \"Spam\"\n}" }, "url": "{{baseUrl}}/posts/{{postId}}/report" } }
      ]
    },
    {
      "name": "Votes",
      "item": [
        { "name": "List Votes", "request": { "method": "GET", "url": "{{baseUrl}}/votes?page=1&limit=20" } },
        { "name": "Get Vote", "request": { "method": "GET", "url": "{{baseUrl}}/votes/{{voteId}}" } },
        {
          "name": "Create Vote",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 201) { pm.collectionVariables.set('voteId', pm.response.json().data.id); }"], "type": "text/javascript" } }],
          "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"title\": \"Best feature?\",\n  \"description\": \"Vote now!\",\n  \"voteType\": \"FREE_VOTE\",\n  \"startsAt\": \"2026-01-01T00:00:00Z\",\n  \"endsAt\": \"2026-12-31T23:59:59Z\",\n  \"options\": [\"Option 1\", \"Option 2\", \"Option 3\"]\n}" }, "url": "{{baseUrl}}/votes" }
        },
        { "name": "Cast Vote", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"optionId\": \"OPTION_ID_HERE\"\n}" }, "url": "{{baseUrl}}/votes/{{voteId}}/vote" } },
        { "name": "Get Results", "request": { "method": "GET", "url": "{{baseUrl}}/votes/{{voteId}}/results" } }
      ]
    },
    {
      "name": "Memberships",
      "item": [
        { "name": "List Plans", "request": { "method": "GET", "url": "{{baseUrl}}/memberships" } },
        { "name": "Purchase Membership", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"membershipId\": \"{{membershipId}}\"\n}" }, "url": "{{baseUrl}}/memberships/purchase" } },
        { "name": "My Memberships", "request": { "method": "GET", "url": "{{baseUrl}}/memberships/my" } }
      ]
    },
    {
      "name": "Tickets",
      "item": [
        { "name": "List Tickets", "request": { "method": "GET", "url": "{{baseUrl}}/tickets" } },
        { "name": "Get Ticket", "request": { "method": "GET", "url": "{{baseUrl}}/tickets/{{ticketId}}" } },
        { "name": "Purchase Ticket", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"ticketId\": \"{{ticketId}}\"\n}" }, "url": "{{baseUrl}}/tickets/purchase" } },
        { "name": "My Tickets", "request": { "method": "GET", "url": "{{baseUrl}}/tickets/my-tickets" } },
        { "name": "Check-In (QR scan)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"qrCode\": \"QR_CODE_DATA\"\n}" }, "url": "{{baseUrl}}/tickets/checkin" } }
      ]
    },
    {
      "name": "Payments (Manual)",
      "item": [
        { "name": "Get Payment Instructions (public)", "request": { "method": "GET", "url": "{{baseUrl}}/manual-payments/instructions" } },
        {
          "name": "Create Manual Payment",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 201) { pm.collectionVariables.set('paymentId', pm.response.json().data.id); }"], "type": "text/javascript" } }],
          "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"amount\": 199,\n  \"currency\": \"ETB\",\n  \"method\": \"MANUAL\",\n  \"metadata\": \"{\\\"type\\\":\\\"MEMBERSHIP\\\",\\\"targetId\\\":\\\"{{membershipId}}\\\",\\\"targetName\\\":\\\"GOLD\\\"}\"\n}" }, "url": "{{baseUrl}}/payments" }
        },
        {
          "name": "Submit Receipt Proof",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 201) { pm.collectionVariables.set('proofId', pm.response.json().data.id); }"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [],
            "body": { "mode": "formdata", "formdata": [
              { "key": "receipt", "type": "file", "src": "/path/to/receipt.jpg" },
              { "key": "senderName", "value": "John Doe", "type": "text" },
              { "key": "senderPhone", "value": "+251911223344", "type": "text" },
              { "key": "transactionRef", "value": "TXN123456", "type": "text" },
              { "key": "paidAt", "value": "2026-06-04T10:00:00Z", "type": "text" },
              { "key": "notes", "value": "Paid via CBE mobile", "type": "text" }
            ] },
            "url": "{{baseUrl}}/manual-payments/{{paymentId}}/proof"
          }
        },
        { "name": "My Proofs", "request": { "method": "GET", "url": "{{baseUrl}}/manual-payments/proofs/my" } },
        { "name": "All Proofs (admin)", "request": { "method": "GET", "url": "{{baseUrl}}/manual-payments/proofs?status=PENDING" } },
        {
          "name": "Approve Proof (admin)",
          "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"decision\": \"APPROVED\"\n}" }, "url": "{{baseUrl}}/manual-payments/proofs/{{proofId}}/review" }
        },
        {
          "name": "Reject Proof (admin)",
          "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"decision\": \"REJECTED\",\n  \"rejectionReason\": \"Receipt is unclear, please reupload\"\n}" }, "url": "{{baseUrl}}/manual-payments/proofs/{{proofId}}/review" }
        }
      ]
    },
    {
      "name": "Leaderboard",
      "item": [
        { "name": "Get Leaderboard", "request": { "method": "GET", "url": "{{baseUrl}}/leaderboard?category=GENERAL&period=WEEKLY" } }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        { "name": "List My Notifications", "request": { "method": "GET", "url": "{{baseUrl}}/notifications" } },
        { "name": "Mark As Read", "request": { "method": "PUT", "url": "{{baseUrl}}/notifications/NOTIFICATION_ID/read" } },
        { "name": "Mark All As Read", "request": { "method": "PUT", "url": "{{baseUrl}}/notifications/read-all" } }
      ]
    },
    {
      "name": "Upload",
      "item": [
        {
          "name": "Upload File",
          "request": {
            "method": "POST",
            "header": [],
            "body": { "mode": "formdata", "formdata": [
              { "key": "file", "type": "file", "src": "/path/to/image.jpg" }
            ] },
            "url": "{{baseUrl}}/upload"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        { "name": "Admin Register User", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"email\": \"newadmin@ch.com\",\n  \"username\": \"newadmin\",\n  \"password\": \"AdminPass123!\",\n  \"fullName\": \"New Admin\",\n  \"role\": \"ADMIN\"\n}" }, "url": "{{baseUrl}}/auth/admin-register" } },
        { "name": "Reset User Password (admin)", "request": { "method": "POST", "url": "{{baseUrl}}/users/{{userId}}/reset-password" } }
      ]
    }
  ]
}
