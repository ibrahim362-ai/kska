# Root .env for docker compose
# This is the ONLY env file you need to run the whole stack.
# Copy to .env (not committed) and fill in real values.

NODE_ENV=development
LOG_LEVEL=info

# ---------- Postgres ----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=community_db
POSTGRES_PORT=5432

# ---------- Redis ----------
REDIS_PORT=6379

# ---------- Backend ports ----------
BACKEND_PORT=5000

# ---------- Dev tools (run with: docker compose --profile tools up) ----------
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
REDIS_INSIGHT_PORT=5540

# ---------- JWT ----------
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=replace-me-access-secret-64-bytes-random
JWT_REFRESH_SECRET=replace-me-refresh-secret-64-bytes-random
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ---------- Cloudinary ----------
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ---------- SMTP ----------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="KSKA <noreply@localhost>"

# ---------- Frontend URLs ----------
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000

# ---------- Optional: Sentry, Firebase ----------
SENTRY_DSN=
FIREBASE_SERVICE_ACCOUNT=
